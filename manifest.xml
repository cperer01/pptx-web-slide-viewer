<?xml version="1.0" encoding="UTF-8"?>
<!--
  Web Slide - PowerPoint content add-in (add-in-only XML manifest).
  This is the manifest format required for sideloading on PowerPoint for Mac.
  The unified JSON manifest does NOT sideload on Mac yet, so do not convert this.

  SourceLocation and icon URLs point at the GitHub Pages host that serves this
  repo: https://cperer01.github.io/pptx-web-slide-viewer/. For local dev with
  server.js instead, swap that origin back to https://localhost:3000.
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="ContentApp">

  <Id>a367605a-b43d-4303-8a3b-a0aa26279d39</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Chaz</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Web Slide"/>
  <Description DefaultValue="Embed and interact with a live webpage inside a slide."/>

  <IconUrl DefaultValue="https://cperer01.github.io/pptx-web-slide-viewer/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://cperer01.github.io/pptx-web-slide-viewer/assets/icon-80.png"/>
  <SupportUrl DefaultValue="https://cperer01.github.io/pptx-web-slide-viewer/"/>

  <!-- Domains the add-in's own top window is allowed to navigate to.
       Add any origin you intend to load directly as the add-in surface here.
       Note: this does NOT override a target site's frame-ancestors policy. -->
  <AppDomains>
    <AppDomain>https://cperer01.github.io</AppDomain>
    <!-- Optional placeholder: add each origin you'll surface directly as the
         add-in's own page. Replace with your real demo host(s) or remove. -->
    <AppDomain>https://demo.bevaya.ai</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Presentation"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://cperer01.github.io/pptx-web-slide-viewer/src/index.html"/>
    <RequestedWidth>800</RequestedWidth>
    <RequestedHeight>450</RequestedHeight>
  </DefaultSettings>

  <!-- ReadWriteDocument is needed to persist the loaded URL in the slide's
       add-in settings so it reopens to the same page. -->
  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
